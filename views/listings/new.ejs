<% layout("/layouts/boilerplate") -%>

  <body>
    <br>

    <h2>Create a new Listing</h2>
    <div class="row">
      <div class="col-8 offset-2">
        <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
          <div>
            <label for="title" class="form-label">Title</label>
            <input type="text" name="listing[title]" placeholder="Enter title" class="form-control" required>
                       <div class="valid-feedback">
      Looks good!
    </div>
          </div>
          <br>
          <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <textarea name="listing[description]" placeholder="Enter description" class="form-control"
              required></textarea>
          </div><br>
          <div class="mb-3">
            <label for="location" class="form-label">Location</label>
            <input type="text" name="listing[location]" placeholder="Enter 
            location" class="form-control" required>
            
          </div><br>

           <div class="mb-3">
            <label for="image" class="form-label"> upload Listing Image </label>
            <input type="file" name="listing[image]" placeholder="Enter image/URL" class="form-control" required>
          </div><br>

          <div class="row">
            <div class="mb-3 col-4">
              <label for="price" class="form-label">Price</label>
              <input type="text" name="listing[price]"  class="form-control" required>
              <div class="invalid-feedback">Please enter a valid price</div>
            </div><br>
            <div class="mb-3 col-8">
              <label for="country" class="form-label">country</label>
              <input type="text" name="listing[country]" placeholder="Enter country" class="form-control" required>
            </div><br>
          </div>
          <button class="btn btn-dark add-btn" type="submit">add</button>
          <br /><br />


        </form>

      </div>
    </div>


      

  </body>