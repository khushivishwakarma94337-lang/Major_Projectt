<% if(success && success.length){ %>
    <div class="alert alert-success" role="alert">
        <% success %>
    <button type="button" class="btn-close ms-5" data-bs-dismiss="alert" aria-label="Close"></button>

</div>

<% } %>
<% if(error && error.length > 0){ %>
  <div style="color:red;">
    <%= error %>
  </div>
<% } %>
